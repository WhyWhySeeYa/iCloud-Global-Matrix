# 默认界面语言：zh-CN、zh-TW 或 en-US
VITE_DEFAULT_LOCALE=zh-CN

# 顶部导航栏标题，对应截图中左上角框选区域
VITE_APP_TITLE=iCloud+ Pricing

# 页面主标题，对应截图中间大标题框选区域
VITE_HERO_TITLE=Global Pricing Matrix.

# 页面副标题，对应截图中间副标题框选区域
VITE_HERO_SUBTITLE=Compare iCloud+ storage plans across different regions and currencies in real-time.

# 可选：Upstash Redis 持久化最近一次成功的价格数据
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
